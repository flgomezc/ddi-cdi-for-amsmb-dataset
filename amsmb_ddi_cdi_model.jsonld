    },
    {
      "@id": "amsmb:CV_Date",
      "@type": "ddi-cdi:ConceptualVariable",
      "dcterms:title": "Year of writing of a notarial charter",
      "dcterms:description": "The calendar year in which the notarial charter was written and authenticated. In notarial documents of the medieval Crown of Aragon, the date is expressed as a standardized Latin date expression using the Roman calendar system (Kalends, Nones, Ides) combined with the year in the Anno Domini reckoning using Roman numerals. Example: 'Vº kalendas madii, anno Domini millesimo CCº XXXº tercio' = 28 April 1233. The complete date (day and month) may be present in the original manuscript and in the PageXML transcription. Only the year is extracted in this variable."
    },
    {
      "@id": "amsmb:RV_Date",
      "@type": "ddi-cdi:RepresentedVariable",
      "dcterms:title": "Date — integer year",
      "ddi-cdi:isConceptualizedBy": {
        "@id": "amsmb:CV_Date"
      },
      "ddi-cdi:hasRepresentation": {
        "@type": "ddi-cdi:NumericRepresentation",
        "dcterms:description": "Integer. Range: 1208–1499. Represents the year of writing in the proleptic Gregorian calendar. Derived by Ramon Sarobe from the standardized Latin date expression during metadata annotation.",
        "ddi-cdi:minimumValue": 1208,
        "ddi-cdi:maximumValue": 1499
      },
      "ddi-cdi:note": "The complete date (day and month) may be present in the original manuscript and in the PageXML transcription files but was not extracted into this variable. Researchers requiring day-level temporal precision should consult the corresponding PageXML file via the hasLogicalAnnotation link on each InstanceValue node."
    },
    {
      "@id": "amsmb:IV_Date",
      "@type": "ddi-cdi:InstanceVariable",
      "dcterms:title": "date (metadata.csv)",
      "ddi-cdi:isRepresentedBy": {
        "@id": "amsmb:RV_Date"
      },
      "ddi-cdi:correspondsTo": {
        "@id": "amsmb:Component_Date"
      },
      "prov:wasGeneratedBy": {
        "@id": "amsmb:Step08_MetadataAnnotation"
      },
      "prov:wasAttributedTo": {
        "@id": "https://orcid.org/0000-0003-2099-3567"
      }
    },
    {
