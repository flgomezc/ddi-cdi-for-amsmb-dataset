    {
      "@id": "amsmb:CV_Reference",
      "@type": "ddi-cdi:ConceptualVariable",
      "dcterms:title": "Archival identifier of a charter",
      "dcterms:description": "The unique identifier that unambiguously designates a specific charter within the dataset. Composed of the archive acronym and the manuscript signature, separated by an underscore. Designed to be globally unique across archive collections and to function as the primary key linking all dataset files (JPEG image, PageXML transcription, CSV metadata row)."
    },
    {
      "@id": "amsmb:RV_Reference",
      "@type": "ddi-cdi:RepresentedVariable",
      "dcterms:title": "Reference — string identifier",
      "ddi-cdi:isConceptualizedBy": {
        "@id": "amsmb:CV_Reference"
      },
      "ddi-cdi:hasRepresentation": {
        "@type": "ddi-cdi:TextRepresentation",
        "dcterms:description": "String. Format: {ARCHIVE_ACRONYM}_{SIGNATURE}. Example: AMSMB_1-1-17. Derived from the concatenation of the 'archive' and 'signature' fields. No missing values — every charter has a unique reference."
      }
    },
    {
      "@id": "amsmb:IV_Reference",
      "@type": "ddi-cdi:InstanceVariable",
      "dcterms:title": "reference (metadata.csv)",
      "ddi-cdi:isRepresentedBy": {
        "@id": "amsmb:RV_Reference"
      },
      "ddi-cdi:correspondsTo": {
        "@id": "amsmb:Component_Reference"
      },
      "prov:wasGeneratedBy": {
        "@id": "amsmb:Step08_MetadataAnnotation"
      },
      "ddi-cdi:note": "Primary key. Also used as the filename stem for the corresponding JPEG and PageXML files (e.g. AMSMB_1-1-17.jpg, AMSMB_1-1-17.xml)."
    },
    {
