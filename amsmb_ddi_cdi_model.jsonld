    {
      "@id": "amsmb:Collection_AMSMB_TIFFs",
      "@type": [
        "ddi-cdi:PhysicalDataSet",
        "prov:Entity"
      ],
      "dcterms:title": "AMSMB digitized parchment collection (TIFF)",
      "dcterms:description": "Annual digitization campaign by AMSMB/AMVD starting in the early 2000s, producing high-resolution TIFF images (up to 650MB each) of over 11,000 charters on parchment from the 13th to 15th centuries. The collection had been fully described using a bespoke cataloguing system since 1985. Not publicly accessible via web — access to the digitized images and catalogue was brokered by Coral Cuadrada through an institutional agreement with the de Sarriera family and the Arxiu Municipal de Vilassar de Dalt.",
      "prov:wasAttributedTo": {
        "@id": "amsmb:org_AMVD"
      },
      "prov:wasAssociatedWith": {
        "@id": "https://orcid.org/0000-0003-4577-2381"
      }
    },
    {
      "@id": "amsmb:Step01_ProjectDesign",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Project design",
      "prov:wasAssociatedWith": [
        {
          "@id": "https://orcid.org/0000-0001-8455-7196"
        },
        {
          "@id": "https://orcid.org/0000-0003-4577-2381"
        },
        {
          "@id": "https://orcid.org/0000-0003-1304-1939"
        }
      ],
      "prov:generated": {
        "@id": "amsmb:Output_ProjectDesign"
      }
    },
    {
      "@id": "amsmb:Output_ProjectDesign",
      "@type": "prov:Entity",
      "dcterms:title": "Project design and data strategy"
    },
    {
      "@id": "amsmb:Step02_DatasetCuration",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Dataset curation",
      "dcterms:description": "Selection of 100 representative digitized charters from the AMSMB parchment collection. Manuscripts were carefully sampled to represent the large variation present in the sources, stratifying across image quality, shape, preservation state, deterioration type, handwriting style, century, and document type. The selection covers at least 80 distinct hands across three centuries (1208–1499) and 29 legal document types. Access to the digitized TIFF collection and the archival catalogue was enabled by Coral Cuadrada through an institutional agreement with the AMSMB and AMVD.",
      "ddi-cdi:follows": {
        "@id": "amsmb:Step01_ProjectDesign"
      },
      "prov:wasAssociatedWith": [
        {
          "@id": "https://orcid.org/0000-0003-4577-2381"
        },
        {
          "@id": "amsmb:person_MarcPrim"
        },
        {
          "@id": "https://orcid.org/0000-0003-2099-3567"
        },
        {
          "@id": "https://orcid.org/0000-0001-8455-7196"
        }
      ],
      "prov:used": {
        "@id": "amsmb:Collection_AMSMB_TIFFs"
      },
      "ddi-cdi:hasSamplingInformation": {
        "@id": "amsmb:SamplingInfo_Curation"
      },
      "prov:generated": {
        "@id": "amsmb:Output_100_selected_charters"
      }
    },
    {
      "@id": "amsmb:SamplingInfo_Curation",
      "@type": "ddi-cdi:SamplingInformation",
      "dcterms:title": "Stratified sampling criteria for charter selection",
      "ddi-cdi:has": [
        {
          "@type": "ddi-cdi:SamplingProcedure",
          "dcterms:description": "Image quality and shape: height-to-width ratios ranging from 0.46 to 1.46; number of lines per charter between 8 and 106."
        },
        {
          "@type": "ddi-cdi:SamplingProcedure",
          "dcterms:description": "Degree of preservation and deterioration types: holes, folds, stains, discoloured areas, ink loss or fading."
        },
        {
          "@type": "ddi-cdi:SamplingProcedure",
          "dcterms:description": "Handwriting style: at least 80 distinct known hands represented, plus several unknown hands."
        },
        {
          "@type": "ddi-cdi:SamplingProcedure",
          "dcterms:description": "Century coverage: 13th century (983 lines), 14th century (942 lines), 15th century (1444 lines)."
        },
        {
          "@type": "ddi-cdi:SamplingProcedure",
          "dcterms:description": "Document type coverage: 29 legal document types represented, from sales and inventories to last wills and marriage contracts."
        }
      ]
    },
    {
      "@id": "amsmb:Output_100_selected_charters",
      "@type": [
        "ddi-cdi:PhysicalDataSet",
        "prov:Entity"
      ],
      "dcterms:title": "100 selected TIFF images of AMSMB charters",
      "dcterms:description": "The 100 charters selected for the dataset, sourced from the AMSMB digitized TIFF collection. Split into train (60), validation (20) and test (20) subsets.",
      "prov:wasDerivedFrom": {
        "@id": "amsmb:Collection_AMSMB_TIFFs"
      }
    },
    {
      "@id": "amsmb:Step03_Preprocessing",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Preprocessing",
      "dcterms:description": "Programmatic conversion of high-resolution TIFF source files to JPEG format using the Pillow (PIL) Python library. Required due to the large size of TIFF files (up to 650MB each), which exceeded the file size limits of eScriptorium and standard dataset distribution formats.",
      "ddi-cdi:follows": {
        "@id": "amsmb:Step02_DatasetCuration"
      },
      "prov:wasAssociatedWith": {
        "@id": "https://orcid.org/0000-0001-8455-7196"
      },
      "prov:used": [
        {
          "@id": "amsmb:Output_100_selected_charters"
        },
        {
          "@id": "amsmb:tool_PIL"
        }
      ],
      "prov:generated": {
        "@id": "amsmb:Output_100_JPEGs"
      }
    },
    {
      "@id": "amsmb:Output_100_JPEGs",
      "@type": [
        "ddi-cdi:PhysicalDataSet",
        "prov:Entity"
      ],
      "dcterms:title": "100 JPEG images of AMSMB charters",
      "dcterms:format": "image/jpeg",
      "prov:wasDerivedFrom": {
        "@id": "amsmb:Output_100_selected_charters"
      },
      "prov:wasAttributedTo": {
        "@id": "https://orcid.org/0000-0001-8455-7196"
      }
    },
    {
      "@id": "amsmb:Step04_Upload",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Upload to eScriptorium",
      "dcterms:description": "Upload of the 100 JPEG images to a locally installed instance of eScriptorium (version 0.14.2) at the Barcelona Supercomputing Center. This registered the images in the transcription platform and prepared them for automatic line segmentation.",
      "ddi-cdi:follows": {
        "@id": "amsmb:Step03_Preprocessing"
      },
      "prov:wasAssociatedWith": {
        "@id": "https://orcid.org/0000-0003-2099-3567"
      },
      "prov:used": [
        {
          "@id": "amsmb:Output_100_JPEGs"
        },
        {
          "@id": "amsmb:tool_eScriptorium"
        }
      ],
      "prov:generated": {
        "@id": "amsmb:Output_eScriptorium_registered"
      }
    },
    {
      "@id": "amsmb:Output_eScriptorium_registered",
      "@type": [
        "ddi-cdi:LogicalRecord",
        "prov:Entity"
      ],
      "dcterms:title": "100 images registered in eScriptorium (local BSC instance)",
      "dcterms:description": "Images loaded into the local eScriptorium instance at BSC, ready for segmentation. The local installation was set up and maintained by Joan Giner (senior research engineer at BSC).",
      "prov:wasDerivedFrom": {
        "@id": "amsmb:Output_100_JPEGs"
      }
    },
    {
      "@id": "amsmb:Step05_AutoSegmentation",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Automatic line segmentation",
      "dcterms:description": "Automatic detection of text line baselines in the 100 manuscript images using the default blla segmentation model provided by Kraken via eScriptorium. Produced an initial set of candidate line segments with polygon coordinates and baselines for each image.",
      "ddi-cdi:follows": {
        "@id": "amsmb:Step04_Upload"
      },
      "prov:wasAssociatedWith": [
        {
          "@id": "https://orcid.org/0000-0003-2099-3567"
        },
        {
          "@id": "https://orcid.org/0000-0001-8455-7196"
        }
      ],
      "prov:used": [
        {
          "@id": "amsmb:Output_eScriptorium_registered"
        },
        {
          "@id": "amsmb:tool_Kraken_blla"
        },
        {
          "@id": "amsmb:tool_eScriptorium"
        }
      ],
      "prov:generated": {
        "@id": "amsmb:Output_CandidateSegments"
      }
    },
    {
      "@id": "amsmb:Output_CandidateSegments",
      "@type": [
        "ddi-cdi:LogicalRecord",
        "prov:Entity"
      ],
      "dcterms:title": "3369 candidate line segments (unvalidated)",
      "dcterms:description": "Automatically detected text line segments with polygon coordinates and baselines. Includes DefaultLine and InterlinearLine types per the simplified SegmOnto vocabulary. Not yet validated — subject to manual correction in the next step.",
      "prov:wasDerivedFrom": {
        "@id": "amsmb:Output_eScriptorium_registered"
      }
    },
    {
      "@id": "amsmb:Step06_ManualCorrection",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Manual line correction",
      "dcterms:description": "Manual review and correction of the automatically detected line segments using eScriptorium. Corrections addressed segmentation errors caused by physical deterioration of the parchment (holes, folds, stains) and complex layout features including DropCapitalZone, GraphicZone:Signum (notarial cross-signatures) and InterlinearLine elements. Lines separated by large gaps or holes were split into two segments. Cross-signature signs (Signum) were also used as line split points.",
      "ddi-cdi:follows": {
        "@id": "amsmb:Step05_AutoSegmentation"
      },
      "prov:wasAssociatedWith": [
        {
          "@id": "https://orcid.org/0000-0003-2099-3567"
        },
        {
          "@id": "https://orcid.org/0000-0001-8455-7196"
        }
      ],
      "prov:used": [
        {
          "@id": "amsmb:Output_CandidateSegments"
        },
        {
          "@id": "amsmb:tool_eScriptorium"
        }
      ],
      "prov:generated": {
        "@id": "amsmb:Output_ValidatedSegments"
      }
    },
    {
      "@id": "amsmb:Output_ValidatedSegments",
      "@type": [
        "ddi-cdi:LogicalRecord",
        "prov:Entity"
      ],
      "dcterms:title": "3369 validated line segments",
      "dcterms:description": "Manually reviewed and corrected line segments. Regions classified using a simplified SegmOnto vocabulary: MainZone, MarginTextZone, DropCapitalZone, GraphicZone:Signum, GraphicZone:Other. Line types: DefaultLine and InterlinearLine.",
      "prov:wasDerivedFrom": {
        "@id": "amsmb:Output_CandidateSegments"
      }
    },
    {
      "@id": "amsmb:Step07_Transcription",
      "@type": [
        "ddi-cdi:ProcessStep",
        "prov:Activity"
      ],
      "dcterms:title": "Transcription",
      "dcterms:description": "Manual transcription of the 3369 validated line segments by expert paleographer Ramon Sarobe, following a semi-diplomatic approach documented in the transcription guidelines. Transcriptions were recorded in eScriptorium and exported as PageXML files. The corpus is written primarily in Medieval Latin with fragments in Medieval Catalan.",
      "ddi-cdi:follows": {
        "@id": "amsmb:Step06_ManualCorrection"
      },
      "prov:wasAssociatedWith": {
        "@id": "https://orcid.org/0000-0003-2099-3567"
      },
      "prov:used": [
        {
          "@id": "amsmb:Output_ValidatedSegments"
        },
        {
          "@id": "amsmb:tool_eScriptorium"
        }
      ],
      "prov:hadPlan": {
        "@id": "amsmb:Plan_TranscriptionGuidelines"
      },
      "prov:generated": {
        "@id": "amsmb:Output_100_PageXMLs"
      }
    },
    {
      "@id": "amsmb:Plan_TranscriptionGuidelines",
      "@type": [
        "prov:Plan",
        "ddi-cdi:ProcessPattern"
      ],
      "dcterms:title": "Semi-diplomatic transcription guidelines",
      "dcterms:description": "Transcription rules authored by Ramon Sarobe for the semi-diplomatic treatment of Medieval Latin and Catalan manuscript text. Designed to balance readability and machine-actionability while preserving philological accuracy.",
      "ddi-cdi:has": [
        {
          "@type": "ddi-cdi:ProcessStep",
          "dcterms:title": "Rule 1 — Allograph reduction",
          "dcterms:description": "Variants of the same letter (allographs) are reduced to their underlying grapheme. In Latin: long 'i' (resembling 'j') transcribed as 'i'; 'v' and 'u' regularized by convention. In Catalan: 'i'/'j' and 'u'/'v' are two distinct graphemes and transcribed as such."
        },
        {
          "@type": "ddi-cdi:ProcessStep",
          "dcterms:title": "Rule 2 — Spelling irregularities",
          "dcterms:description": "Grammatical or spelling irregularities are retained. Exceptions: standard criteria applied for punctuation, capitalization, diacritics and apostrophes; double 'f' at the beginning of a Latin word reduced to single 'f'; 'Signum' (and variants such as Sig+num, Sig++na) always capitalized."
        },
        {
          "@type": "ddi-cdi:ProcessStep",
          "dcterms:title": "Rule 3 — Proper names",
          "dcterms:description": "Proper names are not translated and are transcribed as they appear in the manuscript (capitalized), respecting original white spaces and spelling irregularities (except initial double 'f'). Non-standard word separations are respected. Example: 'Fontisrubei' retained instead of modern Catalan toponym 'Font-Rubí'."
        },
        {
          "@type": "ddi-cdi:ProcessStep",
          "dcterms:title": "Rule 4 — Abbreviations and symbols",
          "dcterms:description": "Abbreviations and symbols are resolved to the full form of the word, with the exception of abbreviated first names (not resolved). Example: 'novint' resolved to 'noverint'; 'B.' not resolved to full name (typically Bernardus or Berengarius)."
        }
      ]
    },
    {
      "@id": "amsmb:Output_100_PageXMLs",
      "@type": [
        "ddi-cdi:PhysicalDataSet",
        "prov:Entity"
      ],
      "dcterms:title": "100 PageXML transcription files",
      "dcterms:format": "application/xml",
