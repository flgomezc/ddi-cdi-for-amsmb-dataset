      }
    },
    {
      "@id": "amsmb:RV_Archive",
      "@type": "ddi-cdi:RepresentedVariable",
      "dcterms:title": "Archive — controlled vocabulary linked to organization",
      "ddi-cdi:isConceptualizedBy": {
        "@id": "amsmb:CV_Archive"
      },
      "ddi-cdi:isDefinedBy": {
        "@id": "amsmb:CD_Archive"
      },
      "ddi-cdi:hasRepresentation": {
