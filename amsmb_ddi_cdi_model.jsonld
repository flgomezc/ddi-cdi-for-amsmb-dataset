        "dcterms:description": "String acronym. Controlled vocabulary linked via owl:sameAs to the corresponding Organization node. Currently only 'AMSMB'. No missing values."
      }
    },
    {
      "@id": "amsmb:IV_Archive",
      "@type": "ddi-cdi:InstanceVariable",
      "dcterms:title": "archive (metadata.csv)",
      "ddi-cdi:isRepresentedBy": {
