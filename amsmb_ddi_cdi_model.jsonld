      "@type": "ddi-cdi:ConceptualVariable",
      "dcterms:title": "Custodian archive of a charter",
      "dcterms:description": "The archive institution that holds the physical charter and made it available for digitization. Identifies the provenance and custody chain of the physical document."
    },
