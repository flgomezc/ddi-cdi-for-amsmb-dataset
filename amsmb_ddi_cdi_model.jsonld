    {
      "@id": "amsmb:Summaries_AMSMB_Charters",
      "@type": "ddi-cdi:DataStore",
      "dcterms:title": "AMSMB charter summaries",
      "dcterms:description": "Contemporary Catalan summaries (dcterms:abstract) for each of the 100 charters, authored by Ramon Sarobe. One node per charter, each sharing the same @id as its corresponding InstanceValue in the WideDataSet. Stored as a separate JSON-LD file (amsmb_charters_summaries.jsonld) and linked to this orchestrator via shared @id references.",
      "owl:sameAs": {
        "@id": "amsmb_charters_summaries.jsonld"
      }
    },
