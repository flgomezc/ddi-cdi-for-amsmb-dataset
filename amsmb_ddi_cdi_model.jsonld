      }
    },
    {
      "@id": "amsmb:CV_Signature",
      "@type": "ddi-cdi:ConceptualVariable",
      "dcterms:title": "Shelfmark (signatura topogràfica) of a charter within its custodian archive",
      "dcterms:description": "The shelfmark — known in Catalan archival practice as 'signatura topogràfica' — is the local identifier assigned to the physical charter within the AMSMB archive's cataloguing system. It encodes the hierarchical physical location of the document: drawer, folder, and charter number, separated by hyphens. The drawer component may be numeric (e.g. '7') or alphanumeric (e.g. 'C1'). Examples: '1-1-17' (drawer 1, folder 1, charter 17), 'C1-F1-09' (drawer C1, folder F1, charter 09), 'C1-F14-55' (drawer C1, folder F14, charter 55). Combined with the archive acronym it forms the global reference identifier."
    },
    {
      "@id": "amsmb:RV_Signature",
      "@type": "ddi-cdi:RepresentedVariable",
      "dcterms:title": "Signature — alphanumeric string",
      "ddi-cdi:isConceptualizedBy": {
        "@id": "amsmb:CV_Signature"
      },
      "ddi-cdi:hasRepresentation": {
        "@type": "ddi-cdi:TextRepresentation",
        "dcterms:description": "String. Hyphen-separated code encoding drawer, folder and charter number. Drawer may be numeric (e.g. '7') or alphanumeric (e.g. 'C1'). Examples: '1-1-17', 'C1-F1-09', 'C1-F14-55'. Local to the AMSMB archive cataloguing system. No missing values."
      }
    },
    {
      "@id": "amsmb:IV_Signature",
      "@type": "ddi-cdi:InstanceVariable",
      "dcterms:title": "signature (metadata.csv)",
      "ddi-cdi:isRepresentedBy": {
        "@id": "amsmb:RV_Signature"
      },
      "ddi-cdi:correspondsTo": {
        "@id": "amsmb:Component_Signature"
      },
      "prov:wasGeneratedBy": {
        "@id": "amsmb:Step08_MetadataAnnotation"
      }
    },
    {
      "@id": "amsmb:sentinel_SineNomine",
      "@type": "ddi-cdi:SentinelValue",
      "ddi-cdi:content": "s.n.",
      "dcterms:description": "Standard Latin archival notation 'sine nomine' (without name). Used when the identity of the notary or scrivener who wrote the charter cannot be determined from the document itself or from the archival record.",
      "skos:notation": "s.n.",
      "owl:sameAs": {
        "@id": "https://www.wikidata.org/wiki/Q257086"
      }
    },
    {
      "@id": "amsmb:CD_Notary",
      "@type": "ddi-cdi:SentinelConceptualDomain",
      "dcterms:title": "Notary name domain with sine nomine sentinel",
      "dcterms:description": "Free-text domain for notary and scrivener names, with a declared sentinel value for unknown or unattributed authorship. Names are transcribed as they appear in the manuscript by Ramon Sarobe, with standard capitalization. Spelling variants of the same name are not normalized.",
      "ddi-cdi:hasSentinelValue": {
        "@id": "amsmb:sentinel_SineNomine"
      }
    },
    {
      "@id": "amsmb:CV_Notary",
      "@type": "ddi-cdi:ConceptualVariable",
      "dcterms:title": "Name of the notary or scrivener of a charter",
      "dcterms:description": "The personal name of the legal professional (notary or scrivener) responsible for writing and authenticating the charter. In medieval notarial practice, the notary's identity is attested by their personal Signum (cross-signature) and by the subscription formula at the end of the document. In 8 cases in this dataset the notary cannot be identified and is recorded as 's.n.' (sine nomine)."
    },
    {
      "@id": "amsmb:RV_Notary",
      "@type": "ddi-cdi:RepresentedVariable",
      "dcterms:title": "Scrivener/notary — free text with sentinel",
      "ddi-cdi:isConceptualizedBy": {
        "@id": "amsmb:CV_Notary"
      },
      "ddi-cdi:isDefinedBy": {
        "@id": "amsmb:CD_Notary"
      },
      "ddi-cdi:hasRepresentation": {
        "@type": "ddi-cdi:TextRepresentation",
        "dcterms:description": "String. Free text. Names transcribed as they appear in the manuscript (capitalized). Sentinel value 's.n.' for unknown notaries (8 occurrences). Spelling variants of the same name across different charters are not normalized in this version of the dataset."
      }
    },
    {
      "@id": "amsmb:IV_Notary",
      "@type": "ddi-cdi:InstanceVariable",
      "dcterms:title": "scrivener/notary (metadata.csv)",
      "ddi-cdi:isRepresentedBy": {
        "@id": "amsmb:RV_Notary"
      },
      "ddi-cdi:correspondsTo": {
        "@id": "amsmb:Component_Notary"
      },
      "prov:wasGeneratedBy": {
        "@id": "amsmb:Step08_MetadataAnnotation"
      },
      "prov:wasAttributedTo": {
        "@id": "https://orcid.org/0000-0003-2099-3567"
      }
    },
    {
      "@id": "amsmb:CV_Type",
      "@type": "ddi-cdi:ConceptualVariable",
      "dcterms:title": "Legal nature of a notarial charter",
      "dcterms:description": "The type of legal act recorded in the charter, determined by its content and formal structure. Classified by Ramon Sarobe according to standard medieval diplomatic typology. 29 distinct types are represented in this dataset, ranging from property transfers (Venda, Permuta, Donació) to personal obligations (Homenatge, Jurament) and testamentary acts (Testament, Clàusula testamentària)."
    },
    {
      "@id": "amsmb:RV_Type",
      "@type": "ddi-cdi:RepresentedVariable",
      "dcterms:title": "Type — controlled vocabulary (29 categories)",
      "ddi-cdi:isConceptualizedBy": {
        "@id": "amsmb:CV_Type"
      },
      "ddi-cdi:isDefinedBy": {
        "@id": "amsmb:ConceptualDomain_DocumentTypes"
      },
      "ddi-cdi:hasRepresentation": {
        "@type": "ddi-cdi:CodeRepresentation",
        "dcterms:description": "String in Catalan. Controlled vocabulary of 29 legal document types defined in ConceptualDomain_DocumentTypes. No missing values."
