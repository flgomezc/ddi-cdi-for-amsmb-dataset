      "@id": "amsmb:Orchestrator",
      "@type": "ddi-cdi:DataStore",
      "dcterms:title": "AMSMB HTR Dataset — DDI-CDI Orchestrator",
      "dcterms:description": "Machine-actionable metadata hub linking archival CSV, manuscript images (JPEG) and structural annotations (PageXML) for the AMSMB HTR dataset of 100 medieval notarial charters (1208–1499).",
      "dcterms:publisher": {
        "@id": "amsmb:org_BSC"
      },
      "dcterms:license": {
        "@id": "https://creativecommons.org/licenses/by-sa/4.0/"
      },
      "dcterms:identifier": "https://dataverse.bsc.es/citation?persistentId=perma:BSC/0VB0MC",
      "dcterms:temporal": "1208/1499",
      "dcterms:language": [
        "la",
        "ca"
      ],
      "schema:citation": [
        "Coll Ardanuy, Mariona; Cuadrada, Coral; Sarobe, Ramon, 2025, 'Dataset for handwritten text recognition in medieval notarial charters written on parchment (1208-1499)', https://dataverse.bsc.es/citation?persistentId=perma:BSC/0VB0MC, BSC Dataverse, V1",
        "Coll Ardanuy, Mariona; Berganzo-Besga, Iban; Sarobe, Ramon; Cuadrada, Coral, 2025, 'Evaluating Handwritten Text Recognition in Medieval Notarial Manuscripts: A New Dataset and Comprehensive Analysis', International Conference on Document Analysis and Recognition (ICDAR)"
      ],
      "dcterms:hasPart": [
